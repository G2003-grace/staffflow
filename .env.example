# Local dev — copy to .env and fill in
# In production (Railway), these are injected automatically by the MySQL plugin
# as MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=staffflow

PORT=5000

# Comma-separated list of allowed origins (your Vercel URL)
FRONTEND_URL=http://localhost:5173
